generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === NextAuth Models ===

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// === App Models ===

model User {
  id          String   @id @default(uuid()) @db.Uuid
  name        String?
  email       String   @unique
  password    String?
  roleGlobal  String   @default("MEMBER") @map("role_global")
  avatarUrl   String?  @map("avatar_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  accounts         Account[]
  sessions         Session[]
  pipelineMembers  PipelineMember[]
  createdPipelines Pipeline[]       @relation("PipelineCreator")
  assignedLeads    Lead[]           @relation("LeadAssignee")
  leadActivities   LeadActivity[]
  assignedTasks    Task[]           @relation("TaskAssignee")

  @@map("profiles")
}

model Pipeline {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdById String?  @map("created_by") @db.Uuid
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  createdBy User?            @relation("PipelineCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members   PipelineMember[]
  stages    Stage[]
  leads     Lead[]

  @@map("pipelines")
}

model PipelineMember {
  id             String   @id @default(uuid()) @db.Uuid
  pipelineId     String   @map("pipeline_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleInPipeline String   @default("member") @map("role_in_pipeline")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, userId])
  @@index([pipelineId])
  @@index([userId])
  @@map("pipeline_members")
}

model Stage {
  id         String   @id @default(uuid()) @db.Uuid
  pipelineId String   @map("pipeline_id") @db.Uuid
  name       String
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@index([pipelineId])
  @@index([pipelineId, position])
  @@map("stages")
}

model Lead {
  id               String   @id @default(uuid()) @db.Uuid
  pipelineId       String   @map("pipeline_id") @db.Uuid
  stageId          String   @map("stage_id") @db.Uuid
  title            String
  email            String?
  phone            String?
  phoneCountryCode String?  @map("phone_country_code")
  whatsapp         String?
  website          String?
  source           String   @default("manual")
  assigneeUserId   String?  @map("assignee_user_id") @db.Uuid
  notes            String?
  outcome          String   @default("open")
  position         Int      @default(0)
  resumo           String?
  nacionalidade    String?
  valor            String?
  linkedin         String?
  facebook         String?
  instagram        String?
  nomeDono         String?  @map("nome_dono")
  emailDono        String?  @map("email_dono")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage      Stage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  assignee   User?          @relation("LeadAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  tags       LeadTag[]
  activities LeadActivity[]
  tasks      Task[]

  @@index([pipelineId])
  @@index([stageId])
  @@index([assigneeUserId])
  @@index([createdAt])
  @@map("leads")
}

model LeadTag {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  tag       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, tag])
  @@index([leadId])
  @@index([tag])
  @@map("lead_tags")
}

model LeadActivity {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  type      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid

  lead    Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@map("lead_activities")
}

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  leadId      String    @map("lead_id") @db.Uuid
  title       String
  description String?
  dueDate     DateTime? @map("due_date") @db.Timestamptz
  status      String    @default("pending")
  assignedTo  String?   @map("assigned_to") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  lead     Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User? @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([assignedTo])
  @@index([dueDate])
  @@map("tasks")
}
